from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from .models import AIRequestCreate, AIRequestRecord, DashboardSummary, Health
from .store import create_request, list_requests, get_request, dashboard_summary, seed

app = FastAPI(title="SecureTheCloud AI Control Plane API", version="0.1.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000", "http://127.0.0.1:3000"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.on_event("startup")
def startup() -> None:
    seed()

@app.get("/health", response_model=Health)
def health() -> Health:
    return Health(status="ok", service="securethecloud-ai-control-plane", lab_mode=True)

@app.get("/api/dashboard", response_model=DashboardSummary)
def dashboard() -> DashboardSummary:
    return dashboard_summary()

@app.get("/api/requests", response_model=list[AIRequestRecord])
def requests() -> list[AIRequestRecord]:
    return list_requests()

@app.post("/api/requests", response_model=AIRequestRecord)
def submit_request(payload: AIRequestCreate) -> AIRequestRecord:
    return create_request(payload)

@app.get("/api/evidence/{request_id}", response_model=AIRequestRecord)
def evidence(request_id: str) -> AIRequestRecord:
    record = get_request(request_id)
    if not record:
        raise HTTPException(status_code=404, detail="Evidence record not found")
    return record
